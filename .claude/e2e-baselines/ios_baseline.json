{
  "_meta": {
    "captured_at": "2026-03-16",
    "plugin_version": "6.17.8",
    "native_sdk_version": "6.17.8",
    "native_sdk_build": "1",
    "platform": "ios",
    "bundle_id": "com.appsflyer.example",
    "simulator": "iPhone 17 (E112EA95-9BAE-4BE1-921C-FCCC39CF5F31)",
    "app_build": "example/build/ios/iphonesimulator/Runner.app",
    "capture_method": "fresh_install — xcrun simctl uninstall + install + launch",
    "note": "All baselines require a fresh install (uninstall + reinstall) before each run. is_first_launch=true is only guaranteed on fresh install. iOS SDK does not log HTTP request bodies in simulator — validate endpoints and HTTP 200s via CFNetwork:Summary logs."
  },

  "fresh_install_procedure": {
    "description": "These exact steps MUST be followed before every baseline validation run.",
    "steps": [
      "xcrun simctl uninstall <SIMULATOR_UDID> com.appsflyer.example",
      "xcrun simctl install <SIMULATOR_UDID> example/build/ios/iphonesimulator/Runner.app",
      "xcrun simctl launch <SIMULATOR_UDID> com.appsflyer.example  (note the returned PID)",
      "sleep 25 (wait for SDK to complete all HTTP calls and conversion callback)",
      "confirm: xcrun simctl spawn <UDID> launchctl list | grep appsflyer shows the PID"
    ],
    "log_collection": [
      "xcrun simctl spawn <UDID> log show --predicate 'processID == <PID>' --last 60s --style compact",
      "filter for: AF_QA | CFNetwork:Summary | network:connection | appsflyer"
    ]
  },

  "lifecycle": {
    "pre_start_sequence": [
      "[AF_QA][initSdk] result: channel registration complete",
      "[AF_QA][AUTO_APIS] --- Running pre-start auto APIs ---",
      "[AF_QA][getVersionNumber] result:",
      "[AF_QA][enableTCFDataCollection] shouldCollect=true",
      "[AF_QA][setConsentDataV2] isUserSubjectToGDPR=false",
      "[AF_QA][setDisableAdvertisingIdentifiers] disabled=false",
      "[AF_QA][disableSKAdNetwork] isDisabled=false",
      "[AF_QA][AUTO_APIS] --- Pre-start auto APIs complete ---",
      "[AF_QA][startSDK] calling..."
    ],
    "post_start_sequence": [
      "[AF_QA][startSDK] result: SUCCESS",
      "[AF_QA][AUTO_APIS] --- Running post-start auto APIs ---",
      "[AF_QA][getSDKVersion] result:",
      "[AF_QA][getAppsFlyerUID] result:",
      "[AF_QA][getHostName] result:",
      "[AF_QA][getHostPrefix] result:",
      "[AF_QA][logEvent(af_demo_launch)] result: true",
      "[AF_QA][logEvent: af_purchase sent] result: true",
      "[AF_QA][logEvent: af_content_view sent] result: true",
      "[AF_QA][setCustomerUserId] id=qa_auto_customer_001",
      "[AF_QA][anonymizeUser] shouldAnonymize=false",
      "[AF_QA][setAdditionalData] customData={qa_key:qa_value, auto_run:true}",
      "[AF_QA][setSharingFilterForPartners] partners=[demo_partner]",
      "[AF_QA][AUTO_APIS] --- Post-start auto APIs complete ---"
    ],
    "native_markers": [
      "AppsFlyer Debug: handle deep link",
      "Identity resolved as app<com.appsflyer.example"
    ]
  },

  "api_results": {
    "getVersionNumber": {
      "rule": "exact",
      "expected": "6.17.8",
      "log_pattern": "[AF_QA][getVersionNumber] result: {VALUE}"
    },
    "getSDKVersion": {
      "rule": "contains",
      "expected": "6.17",
      "log_pattern": "[AF_QA][getSDKVersion] result: {VALUE}"
    },
    "getHostName": {
      "rule": "exact",
      "expected": "appsflyersdk.com",
      "log_pattern": "[AF_QA][getHostName] result: {VALUE}"
    },
    "getHostPrefix": {
      "rule": "present_and_non_empty",
      "log_pattern": "[AF_QA][getHostPrefix] result: {VALUE}"
    },
    "getAppsFlyerUID": {
      "rule": "pattern",
      "pattern": "^\\d+-\\d+$",
      "log_pattern": "[AF_QA][getAppsFlyerUID] result: {VALUE}"
    }
  },

  "http_requests": {
    "description": "iOS SDK does not log HTTP request payloads in simulator logs. Validate using CFNetwork:Summary response_status=200 lines and network:connection endpoint URLs.",
    "how_to_validate": [
      "Count CFNetwork:Summary lines with response_status=200 — must be >= 5 (DDL + launch + GCD + inapps x3 minimum)",
      "For each expected endpoint, confirm a [com.apple.network:connection] line for that hostname appeared",
      "The conversion callback arriving proves the GCD request succeeded"
    ],
    "expected_endpoints": {
      "cdn_settings": {
        "url_contains": "cdn-settings.appsflyersdk.com/ios/v1",
        "log_pattern": "[com.apple.network:connection].*cdn-settings.appsflyersdk.com",
        "expected_response_status": 200
      },
      "ddl": {
        "url_contains": "dlsdk.appsflyersdk.com/v1.0/ios/",
        "log_pattern": "[com.apple.network:connection].*dlsdk.appsflyersdk.com",
        "expected_response_status": 200
      },
      "launch_event": {
        "url_contains": "launches.appsflyersdk.com/api/v6.17/iosevent",
        "log_pattern": "[com.apple.network:connection].*launches.appsflyersdk.com",
        "expected_response_status": 200,
        "note": "Must use iosevent path, not androidevent"
      },
      "gcd_conversion": {
        "url_contains": "gcdsdk.appsflyersdk.com",
        "expected_response_status": 200,
        "proof": "onInstallConversionData callback delivery is proof of GCD 200"
      },
      "inapps": {
        "url_contains": "inapps.appsflyersdk.com/api/v6.17/iosevent",
        "log_pattern": "[com.apple.network:connection].*inapps.appsflyersdk.com",
        "expected_response_status": 200,
        "note": "Must use iosevent path, not androidevent"
      },
      "skad": {
        "url_contains": "skadsdk.appsflyersdk.com",
        "expected_response_status": 200
      }
    },
    "minimum_200_responses": 5,
    "cfnetwork_summary_log_pattern": "response_status=200",
    "note": "Each CFNetwork:Summary line with response_status=200 represents one successful HTTP round-trip. Count these to confirm all SDK calls were acknowledged."
  },

  "callbacks": {
    "onInstallConversionData": {
      "expected": true,
      "log_pattern": "[AF_QA][CALLBACK][onInstallConversionData] received: {PAYLOAD}",
      "stable_fields": {
        "status": "success",
        "af_status": "Organic",
        "af_message": "organic install"
      },
      "fresh_install_fields": {
        "is_first_launch": true,
        "note": "is_first_launch MUST be true after a fresh install. If false, the install was not genuinely fresh — stop and reinvestigate."
      },
      "dynamic_fields": ["install_time"]
    },
    "onDeepLinking": {
      "expected": true,
      "log_pattern": "[AF_QA][CALLBACK][onDeepLinking] received: status=Status.NOT_FOUND",
      "stable_fields": {
        "status": "Status.NOT_FOUND"
      },
      "note": "On iOS fresh install with no incoming URL, onDeepLinking fires with NOT_FOUND. This was confirmed on fresh install — different from warm launch behaviour."
    },
    "onAppOpenAttribution": {
      "expected": false
    },
    "onConversionDataFail": {
      "expected": false
    }
  },

  "events": {
    "af_demo_launch": {
      "expected": true,
      "result_expected": true,
      "log_pattern": "[AF_QA][logEvent(af_demo_launch)] result: true",
      "dart_payload": {
        "platform": "ios",
        "plugin_version": "6.17.8"
      },
      "note": "platform must be ios — validated at Dart level. HTTP payload body not visible in iOS simulator logs."
    },
    "af_purchase": {
      "expected": true,
      "result_expected": true,
      "log_pattern": "[AF_QA][logEvent: af_purchase sent] result: true",
      "dart_payload": {
        "af_content_id": "auto_product_001",
        "af_currency": "USD",
        "af_revenue": 9.99,
        "af_quantity": 1,
        "source": "auto_on_launch"
      }
    },
    "af_content_view": {
      "expected": true,
      "result_expected": true,
      "log_pattern": "[AF_QA][logEvent: af_content_view sent] result: true",
      "dart_payload": {
        "af_content_id": "auto_content_001",
        "af_content_type": "demo_page",
        "af_currency": "USD",
        "source": "auto_on_launch"
      }
    }
  },

  "ios_specific": {
    "skadnetwork_active": {
      "rule": "confirm_api_called",
      "log_pattern": "[AF_QA][disableSKAdNetwork] isDisabled=false"
    },
    "skadnetwork_error_on_simulator": {
      "rule": "warn_not_fail",
      "log_pattern": "SKANErrorDomain Code=10",
      "note": "Expected on simulator — cannot register SKAdNetwork conversion values without App Store session."
    },
    "iosevent_endpoint": {
      "rule": "present",
      "log_pattern": "iosevent",
      "note": "All HTTP requests must use iosevent path (not androidevent)"
    },
    "android_apis_must_not_appear": {
      "rule": "absent",
      "patterns": [
        "[AF_QA][setCollectIMEI]",
        "[AF_QA][setCollectAndroidId]",
        "[AF_QA][performOnDeepLinking]"
      ],
      "note": "Android-only APIs must be platform-guarded and must not fire on iOS"
    }
  },

  "known_warnings": {
    "skadnetwork_simulator_error": {
      "rule": "warn_not_fail",
      "log_pattern": "SKANErrorDomain",
      "note": "Expected on simulator."
    }
  },

  "must_not_contain": [
    "[AF_QA][startSDK] error:",
    "[AF_QA][initSdk] error:",
    "response_status=4",
    "response_status=5",
    "Fatal Exception",
    "FATAL"
  ]
}
